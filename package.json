    "zip:firefox": "wxt zip -b firefox --mv3",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "test": "vitest"
  },
  "type": "module",
  "dependencies": {
    "@neodrag/svelte": "^3.0.0-next.8",
    "@tailwindcss/vite": "^4.2.2",
    "liquidjs": "^10.25.2",
    "tailwindcss": "^4.2.2"
  }
}
